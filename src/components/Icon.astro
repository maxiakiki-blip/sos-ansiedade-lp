---
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 26, class: cls = '' } = Astro.props;

const icons = import.meta.glob<string>('../icons/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
let svg = icons[`../icons/${name}.svg`] ?? '';
svg = svg
  .replace(/<!--[\s\S]*?-->/g, '')
  .replace(/<svg([^>]*)>/, (_m, attrs: string) => {
    const cleaned = attrs
      .replace(/\s(width|height)="[^"]*"/g, '')
      .replace(/stroke-width="[^"]*"/, 'stroke-width="1.5"');
    return `<svg${cleaned} width="${size}" height="${size}" class="${cls}" aria-hidden="true" focusable="false">`;
  });
---

<Fragment set:html={svg} />
