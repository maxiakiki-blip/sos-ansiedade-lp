---
import { CHECKOUT_URL } from '../consts';
---

<section class="section fechamento" aria-labelledby="fechamento-title">
  <div class="container narrow fechamento-inner">
    <h2 id="fechamento-title" class="reveal">
      A próxima crise pode vir. A diferença é que agora você vai saber o que fazer.
    </h2>
    <a href={CHECKOUT_URL} data-checkout class="btn reveal" style="--reveal-delay: 100ms">
      Quero começar agora
    </a>
  </div>
</section>

<style>
  .fechamento-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(28px, 4vw, 40px);
  }
</style>
